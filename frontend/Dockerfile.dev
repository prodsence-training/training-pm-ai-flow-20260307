# Frontend Development & Test Dockerfile
FROM node:18

WORKDIR /app

# 安装 Playwright 所需的系统依赖（使用 Debian/Ubuntu apt）
RUN apt-get update && apt-get install -y \
    chromium \
    firefox-esr \
    dumb-init \
    && rm -rf /var/lib/apt/lists/*

# 安装 npm 依赖
COPY package*.json ./
RUN npm ci

# 复制源代码
COPY . .

# 设置环境变量
ENV NEXT_PUBLIC_API_URL=http://backend:8000/api
ENV NODE_ENV=development

# 安装 Playwright 浏览器（使用系统浏览器）
RUN npx playwright install-deps && \
    npx playwright install chromium firefox webkit

EXPOSE 3000

ENTRYPOINT ["dumb-init", "--"]
CMD ["npm", "run", "dev"]
